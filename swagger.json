      "/api/admin/scoped-issues": {
        "get": {
          "summary": "Get issues scoped by admin level",
          "description": "Returns issues based on the admin's clearance level:\n  - woreda_admin: issues in their woreda\n  - city_admin: issues in their city\n  - zone_admin: issues in their zone\n  - regional_admin: issues in their region\n  - federal_admin: all issues\n",
          "tags": [
            "Admin"
          ],
          "security": [
            {
              "bearerAuth": []
            }
          ],
          "parameters": [
            {
              "in": "query",
              "name": "status",
              "schema": {
                "type": "string",
                "description": "Filter issues by status (e.g., reported, verified, assigned, in_progress, resolved)"
              }
            },
            {
              "in": "query",
              "name": "category",
              "schema": {
                "type": "string",
                "description": "Filter issues by category (e.g., electricity, water)"
              }
            },
            {
              "in": "query",
              "name": "page",
              "schema": {
                "type": "integer",
                "default": 1,
                "description": "Page number for pagination"
              }
            },
            {
              "in": "query",
              "name": "limit",
              "schema": {
                "type": "integer",
                "default": 20,
                "description": "Number of issues per page"
              }
            }
          ],
          "responses": {
            "200": {
              "description": "List of issues scoped by admin clearance",
              "content": {
                "application/json": {
                  "example": {
                    "success": true,
                    "issues": [
                      {
